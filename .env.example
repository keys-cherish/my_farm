BOT_TOKEN=your_telegram_bot_token_here
DATABASE_URL=postgresql://user:password@localhost:5432/farm_db

# 允许的群组 (username, 不带@)
ALLOWED_CHAT_USERNAMES=
# 允许的话题ID (逗号分隔, 为空则允许群内所有话题)
ALLOWED_TOPIC_THREAD_IDS=
# 允许的群组ID (逗号分隔, 为空则用username匹配)
ALLOWED_CHAT_IDS=

# Logging
LOG_LEVEL=INFO
LOG_CONSOLE_LEVEL=INFO
LOG_DIR=logs
LOG_JSON=0
LOG_QUEUE_SIZE=10000
LOG_FILE_MAX_BYTES=10485760
LOG_BACKUP_COUNT=7
LOG_SLOW_COMMAND_MS=500
LOG_SLOW_JOB_MS=1000
DB_SLOW_MS=120
DB_LOG_DEBUG=0
